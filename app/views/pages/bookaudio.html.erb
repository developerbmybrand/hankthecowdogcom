<div class="listview">
<h1>Audio Excerpts</h1>	
<h3 class="subtitle">Listen to samples of Hank audio books.</h3>	

<% @books.each do |book| %>

  <script language="javascript">
      $(document).ready(function() {
          $("#jquery_jplayer_<%= book.id %>").jPlayer({
              ready: function (event) {
                  $(this).jPlayer("setMedia", {
                      mp3:"<%= book.book_audio.url %>",
                  });
              },
              swfPath: "/javascripts",
              supplied: "mp3",
              wmode: "window",
              cssSelectorAncestor: "#jp_interface_<%= book.id %>"
          });
      });
  </script>

  <div class="agg">
      <a class="thumb" href="/books/<%= book.id %>"><%= image_tag(book.book_image.thumb.url) if book.book_image? %></a>
      <h2><%= book.book_title %></h2>
      <span class="volume"><%= book.book_volume_number %></span>

      <div class="player">      
        <div id="jquery_jplayer_<%= book.id %>" class="jp-jplayer"></div>
      
        <div id="jp_interface_<%= book.id %>" class="jp-audio">
        <div class="jp-gui jp-interface">
            <div class="jp-type-single">
            <ul class="jp-controls">
                <li><a href="javascript:;" class="jp-play" tabindex="1">play</a></li>
                <li><a href="javascript:;" class="jp-pause" tabindex="1">pause</a></li>
                <li><a href="javascript:;" class="jp-stop" tabindex="1">stop</a></li>
            </ul>
            <div class="jp-progress">
                <div class="jp-seek-bar">
                    <div class="jp-play-bar"></div>
                </div>
            </div>
            <div class="jp-volume-bar">
                <div class="jp-volume-bar-value"></div>
            </div>
            <div class="jp-time-holder">
                <div class="jp-current-time"></div>
                <div class="jp-duration"></div>
            </div>
            </div>
        </div>
        </div>
      </div>
        <a href="/books/<%= book.id %>" class="more">More</a>	
  </div>
            
				

<% end %>

</div>