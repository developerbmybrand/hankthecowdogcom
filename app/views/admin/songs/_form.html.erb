<%= form_for([:admin, @song], :html => {:multipart => true}) do |f| %>
    <% if @song.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@song.errors.count, "error") %> prohibited this song from being saved:</h2>

      <ul>
      <% @song.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
      </ul>
    </div>
    <% end %>

    <div class="field">
      Title<br />
      <%= f.text_field :title %>
    </div>
    <div class="field">
      Artist<br />
      <%= f.text_field :artist %>
    </div>
    <div class="field">
      Audio File (M4R)<br />
      <%= @song.song_audio if @song.song_audio?%>
      <br>
      <%= f.file_field :song_audio %>
      <%= f.hidden_field :song_audio_cache %>
    </div>
    <div class="field">
      Store URL<br />
      <%= f.text_field :store_link_url %>
    </div>

    <div class="actions">
        <%= f.submit %>
    </div>
<% end %>
