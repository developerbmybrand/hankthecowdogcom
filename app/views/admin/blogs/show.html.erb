<h1>Blog Post</h1>

<p>
  <b>Author:</b>
  <%= User.find(@blog.user_id).full_name %>
</p>

<p>
  <b>Title:</b>
  <%= @blog.blog_title %>
</p>

<p>
  <b>Body:</b>
  <br>
  <%= raw(@blog.blog_body) %>
</p>

<p>
  <b>Author:</b>
  <%= @blog.blog_author %>
</p>

<% if @blog.blog_image? && !@blog.blog_image.nil? %>
<p>
  <b>Image:</b>
  <br>
  <%= image_tag(@blog.blog_image.url) if @blog.blog_image? %>
</p>
<% end %>

<p>
  <b>Date:</b>
  <%= @blog.blog_postdate.strftime("%A, %B %d, %Y") %>
</p>

<p>
  <b>Published?</b>
  <%= @blog.blog_published? ? "Yes" : "No" %>
</p>

<div class="actions2">
<%= link_to 'Edit', edit_admin_blog_path(@blog), :class => 'button2' %> 
<%= link_to 'Back', admin_blogs_path, :class => 'button2' %> 
<%= link_to 'Delete', [:admin, @blog], :confirm => 'Are you sure?', :method => :delete, :class => 'button2' %>
</div>