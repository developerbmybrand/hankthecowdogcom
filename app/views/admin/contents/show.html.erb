<p>
  <b>Page:</b>
  <%= TypeContentPage.find(@content.type_content_page_id).type_name %>
</p>

<p>
  <b>Title:</b>
  <%= @content.content_title %>
</p>

<p>
  <b>Body:</b>
  <%= raw(@content.content_text) %>
</p>

<% if @content.content_image? && !@content.content_image.nil? %>
<p>
  <b>Image:</b>
  <br>
  <%= image_tag(@content.content_image.url) if @content.content_image? %>
</p>
<% end %>
<div class="actions2">
<%= link_to 'Edit', edit_admin_content_path(@content), :class => 'button2' %> 
<%= link_to 'Back', admin_contents_path, :class => 'button2' %> 
<%= link_to 'Delete', [:admin, @content], :confirm => 'Are you sure?', :method => :delete, :class => 'button2' %>
</div>