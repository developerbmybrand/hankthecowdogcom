<p id="notice"><%= notice %></p>

<p>
  <b>Title:</b>
  <%= @bookother.book_title %>
</p>

<p>
  <b>Description:</b>
  <%= raw(@bookother.book_desc) %>
</p>

<p>
  <b>Excerpt Title:</b>
  <%= raw(@bookother.book_excerpt_title) %>
</p>

<p>
  <b>Excerpt:</b>
  <%= raw(@bookother.book_excerpt_detail) %>
</p>

<p>
  <b>Volume:</b>
  <%= @bookother.book_volume_number %>
</p>

<p>
  <b>Cover Image:</b>
  <%= image_tag(@bookother.book_image.thumb.url) if @bookother.book_image? %>
</p>

<p>
  <b>Store Link:</b>
  <a href="<%= @bookother.book_link %>"><%= @bookother.book_link %></a>
</p>

<p>
  <b>Published:</b>
  <%= @bookother.book_published? ? "Yes" : "No" %>
</p>

<%= link_to 'Edit', edit_admin_book_path(@bookother) %> |
<%= link_to 'Back', admin_books_path %> |
<%= link_to 'Delete', [:admin, @bookother], :confirm => 'Are you sure?', :method => :delete %>
