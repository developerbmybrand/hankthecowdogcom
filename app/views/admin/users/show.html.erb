<h1>User</h1>

<p>
  <b>Email:</b>
  <%= @user.email %>
</p>

<p>
  <b>First Name:</b>
  <%= @user.first_name %>
</p>

<p>
  <b>Last Name:</b>
    <%= @user.last_name %>
</p>
<div class="actions2">
<%= link_to 'Edit', edit_admin_user_path(@user), :class => 'button2' %> 
<%= link_to 'Back', admin_users_path, :class => 'button2' %> 
<%= link_to 'Delete', [:admin, @user], :confirm => 'Are you sure?', :method => :delete, :class => 'button2' %>
</div>